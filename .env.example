# Personal access token (simplest) — get one at https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=

# OR: OAuth2 credentials — create an app at https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Tokens — populated by `oura auth`
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=
